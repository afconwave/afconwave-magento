<?xml version="1.0"?>
<!--
    AfconWave Gateway — Dependency Injection Configuration
    Registers the AfconWave payment model as a Magento payment method adapter.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Register AfconWave as a payment method facade -->
    <virtualType name="AfconWaveGatewayFacade" type="Magento\Payment\Model\Method\Adapter">
        <arguments>
            <argument name="code" xsi:type="const">AfconWave\Payment\Model\Payment\AfconWave::CODE</argument>
            <argument name="formBlockType" xsi:type="string">Magento\Payment\Block\Form</argument>
            <argument name="infoBlockType" xsi:type="string">Magento\Payment\Block\Info</argument>
            <argument name="valueHandlerPool" xsi:type="object">AfconWaveValueHandlerPool</argument>
        </arguments>
    </virtualType>

    <!-- Value handler pool for reading gateway config -->
    <virtualType name="AfconWaveValueHandlerPool" type="Magento\Payment\Gateway\Config\ValueHandlerPool">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="string">AfconWaveConfigValueHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="AfconWaveConfigValueHandler" type="Magento\Payment\Gateway\Config\ConfigValueHandler">
        <arguments>
            <argument name="configInterface" xsi:type="object">AfconWaveGatewayConfig</argument>
        </arguments>
    </virtualType>

    <virtualType name="AfconWaveGatewayConfig" type="Magento\Payment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">AfconWave\Payment\Model\Payment\AfconWave::CODE</argument>
        </arguments>
    </virtualType>

    <!-- Register the ConfigProvider for checkout UI -->
    <type name="Magento\Checkout\Model\CompositeConfigProvider">
        <arguments>
            <argument name="configProviders" xsi:type="array">
                <item name="afconwave_gateway_config_provider" xsi:type="object">AfconWave\Payment\Model\Ui\ConfigProvider</item>
            </argument>
        </arguments>
    </type>

</config>
